{
  "name": "baconfy/variants",
  "description": "Composable API resources for Laravel via server-side variants",
  "type": "library",
  "license": "AGPL-3.0-only",
  "keywords": [
    "laravel",
    "json-resource",
    "api-resource",
    "variants",
    "composable"
  ],
  "authors": [
    {
      "name": "Baconfy",
      "email": "hi@baconfy.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/http": "^12",
    "illuminate/support": "^12"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^4.0",
    "laravel/pint": "^1.0",
    "larastan/larastan": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Baconfy\\Variants\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Baconfy\\Variants\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest --parallel --compact",
    "test:types": "phpstan analyse",
    "format": "pint",
    "test:all": [
      "@test",
      "@test:coverage",
      "@test:types"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
